{
  "name": "groweldruida-ns-sync",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker que sincroniza el catalogo de Natural Systems a Supabase para Grow El Druida",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "trigger": "curl -X POST \"$WORKER_URL/sync\" -H \"X-Trigger-Secret: $TRIGGER_SECRET\""
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0"
  }
}
